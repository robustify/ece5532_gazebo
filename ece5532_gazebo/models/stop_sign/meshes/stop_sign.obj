# U.S. Stop Sign — 30-inch flat-to-flat octagon panel
# Units: meters
# Face normal: +X axis  |  Horizontal: Y axis  |  Vertical: Z axis
# Origin: sign center
# Edge length: 12.426 in = 0.3156 m  |  Flat-to-flat: 30 in = 0.762 m
# Circumradius: 0.4124 m  |  Apothem (flat-to-flat/2): 0.3810 m
# Panel thickness: 3 mm

mtllib stop_sign.mtl

# -------------------------------------------------------
# Vertices: front face (x = +0.0015)
# Ordered CCW when viewed from +X (from the front)
# Angles: 22.5, 67.5, 112.5, 157.5, 202.5, 247.5, 292.5, 337.5 deg
# -------------------------------------------------------
v  0.0015  0.3810  0.1578
v  0.0015  0.1578  0.3810
v  0.0015 -0.1578  0.3810
v  0.0015 -0.3810  0.1578
v  0.0015 -0.3810 -0.1578
v  0.0015 -0.1578 -0.3810
v  0.0015  0.1578 -0.3810
v  0.0015  0.3810 -0.1578
v  0.0015  0.0000  0.0000

# -------------------------------------------------------
# Vertices: back face (x = -0.0015)
# -------------------------------------------------------
v -0.0015  0.3810  0.1578
v -0.0015  0.1578  0.3810
v -0.0015 -0.1578  0.3810
v -0.0015 -0.3810  0.1578
v -0.0015 -0.3810 -0.1578
v -0.0015 -0.1578 -0.3810
v -0.0015  0.1578 -0.3810
v -0.0015  0.3810 -0.1578
v -0.0015  0.0000  0.0000

# -------------------------------------------------------
# Texture coordinates (UV) for front face only
# u = (Y + apothem) / (2*apothem),  v = (Z + apothem) / (2*apothem)
# apothem = 0.9197;  1/sqrt(2) = 0.7071;  1 - 1/sqrt(2) = 0.2929
# image_x = u * W,  image_y = (1 - v) * H  (row 0 = sign top)
# -------------------------------------------------------
vt 0.5000 0.5000
vt 1.0000 0.7071
vt 0.7071 1.0000
vt 0.2929 1.0000
vt 0.0000 0.7071
vt 0.0000 0.2929
vt 0.2929 0.0000
vt 0.7071 0.0000
vt 1.0000 0.2929

# -------------------------------------------------------
# Normals
# -------------------------------------------------------
vn  1.0000  0.0000  0.0000
vn -1.0000  0.0000  0.0000
vn  0.0000  1.0000  0.0000
vn  0.0000  0.7071  0.7071
vn  0.0000  0.0000  1.0000
vn  0.0000 -0.7071  0.7071
vn  0.0000 -1.0000  0.0000
vn  0.0000 -0.7071 -0.7071
vn  0.0000  0.0000 -1.0000
vn  0.0000  0.7071 -0.7071

# -------------------------------------------------------
# Front face — UV-mapped texture (fan from center v9/vt1)
# f  v/vt/vn  ...
# -------------------------------------------------------
usemtl stop_face
g sign_front
f  9/1/1  1/2/1  2/3/1
f  9/1/1  2/3/1  3/4/1
f  9/1/1  3/4/1  4/5/1
f  9/1/1  4/5/1  5/6/1
f  9/1/1  5/6/1  6/7/1
f  9/1/1  6/7/1  7/8/1
f  9/1/1  7/8/1  8/9/1
f  9/1/1  8/9/1  1/2/1

# -------------------------------------------------------
# Back face — aluminum gray (fan from center v18, CW from +X)
# -------------------------------------------------------
usemtl stop_back
g sign_back
f 18//2  11//2  10//2
f 18//2  12//2  11//2
f 18//2  13//2  12//2
f 18//2  14//2  13//2
f 18//2  15//2  14//2
f 18//2  16//2  15//2
f 18//2  17//2  16//2
f 18//2  10//2  17//2

# -------------------------------------------------------
# Edge faces — white retroreflective border
# Winding: (back_start - front_start) x (front_end - front_start) → outward
# -------------------------------------------------------
usemtl stop_white
g sign_edge

# Side 1: v8 -> v1  (rightmost,  337.5°->22.5°,   normal +Y)
f  8//3  17//3  10//3
f  8//3  10//3   1//3

# Side 2: v1 -> v2  (upper-right, 22.5°->67.5°,   normal +Y+Z)
f  1//4  10//4  11//4
f  1//4  11//4   2//4

# Side 3: v2 -> v3  (top,         67.5°->112.5°,  normal +Z)
f  2//5  11//5  12//5
f  2//5  12//5   3//5

# Side 4: v3 -> v4  (upper-left, 112.5°->157.5°,  normal -Y+Z)
f  3//6  12//6  13//6
f  3//6  13//6   4//6

# Side 5: v4 -> v5  (leftmost,  157.5°->202.5°,   normal -Y)
f  4//7  13//7  14//7
f  4//7  14//7   5//7

# Side 6: v5 -> v6  (lower-left, 202.5°->247.5°,  normal -Y-Z)
f  5//8  14//8  15//8
f  5//8  15//8   6//8

# Side 7: v6 -> v7  (bottom,     247.5°->292.5°,  normal -Z)
f  6//9  15//9  16//9
f  6//9  16//9   7//9

# Side 8: v7 -> v8  (lower-right, 292.5°->337.5°, normal +Y-Z)
f  7//10  16//10  17//10
f  7//10  17//10   8//10
